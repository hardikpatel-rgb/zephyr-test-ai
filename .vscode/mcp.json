{
	"inputs": [],
	"servers": {
		"atlassian-mcp-server": {
			"url": "https://mcp.atlassian.com/v1/mcp",
			"type": "http"
		},

		"figma-remote": {
      		"type": "stdio",
      		"command": "npx",
      		"args": [
       			 "-y",
       			 "figma-developer-mcp",
       			 "--stdio"
     		 ],
     		 "env": {
       		 "FIGMA_API_KEY": "${workspaceFolder}/.env"
     	 }
   	 }
	}
}